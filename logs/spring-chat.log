    u.id as senderId, u.username as senderUsername, u.avatar_url as senderAvatar,
    ms.status as myStatus
FROM messages m
INNER JOIN users u ON m.sender_id = u.id
LEFT JOIN message_statuses ms ON ms.message_id = m.id AND ms.user_id = ?
WHERE m.conversation_id = ?
  AND (? IS NULL OR (
      m.created_at < ?
      OR (m.created_at = ? AND m.id < ?)
  ))
  AND NOT EXISTS (SELECT 1 FROM message_hidden mh WHERE mh.message_id = m.id AND mh.user_id = ?)
ORDER BY m.created_at DESC, m.id DESC fetch first ? rows only

