    u.avatar_url                                 AS "avatarUrl",
    CASE
        WHEN EXISTS (
            SELECT 1 FROM friendships f
            WHERE (
                (f.requester_id = ? AND f.addressee_id = u.id)
             OR (f.requester_id = u.id AND f.addressee_id = ?)
            )
            AND f.status = 'ACCEPTED'
        ) THEN 'FRIENDS'
        WHEN EXISTS (
            SELECT 1 FROM friendships f
            WHERE f.requester_id = ?
              AND f.addressee_id = u.id
              AND f.status = 'PENDING'
        ) THEN 'PENDING_SENT'
        WHEN EXISTS (
            SELECT 1 FROM friendships f
            WHERE f.requester_id = u.id
              AND f.addressee_id = ?
              AND f.status = 'PENDING'
        ) THEN 'PENDING_RECEIVED'
        ELSE 'NONE'
    END AS "friendRelation"
FROM users u
WHERE u.id     != ?
  AND u.status  = 'ACTIVE'
  AND (u.username ILIKE ? OR u.full_name ILIKE ?)
  AND NOT EXISTS (
      SELECT 1 FROM friendships f
      WHERE f.status       = 'BLOCKED'
        AND f.requester_id = u.id
        AND f.addressee_id = ?
  )
ORDER BY u.username ASC fetch first ? rows only

